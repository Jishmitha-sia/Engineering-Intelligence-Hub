# Engineering Intelligence Hub - Environment Configuration Template
# Copy this file to .env and update the values for your environment
#
#   Windows:  Copy-Item .env.example .env
#   Linux/Mac: cp .env.example .env
#
# See docs/setup.md for full setup instructions.

# Application Environment
ENVIRONMENT=development
DEBUG=false
APP_NAME="Engineering Intelligence Hub"
VERSION=0.1.0

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://engineering_hub:engineering_hub@localhost:5432/engineering_hub
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Authentication & Security
JWT_SECRET_KEY=your-secret-key-change-this-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_MIN_LENGTH=8

# CORS Configuration
ALLOWED_HOSTS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=*

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.md

# AI/ML Configuration
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
DEFAULT_LLM=qwen3:8b
EMBEDDING_DIMENSION=384

# Document Processing Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_CHUNKS_PER_DOCUMENT=10000

# Search Configuration
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_LIMIT=100
SIMILARITY_THRESHOLD=0.5
RERANK_TOP_K=5

# Rate Limiting Configuration
RATE_LIMIT_UNAUTHENTICATED=10/minute
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_UPLOADS=20/hour

# Monitoring Configuration
ENABLE_PROMETHEUS=true
ENABLE_LOGGING=true
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7

# Background Task Configuration
TASK_RETRY_MAX_ATTEMPTS=3
TASK_RETRY_DELAY=5

# GitHub Integration Configuration
GITHUB_TIMEOUT=300
GITHUB_TEMP_DIR=./tmp/github

# Development/Testing Overrides
# Uncomment for testing environment
# ENVIRONMENT=testing
# DATABASE_URL=postgresql+asyncpg://test:test@localhost:5432/test_engineering_hub
# JWT_SECRET_KEY=test-secret-key-for-testing-only-not-production-safe
# UPLOAD_DIR=./test_uploads
# GITHUB_TEMP_DIR=./test_tmp